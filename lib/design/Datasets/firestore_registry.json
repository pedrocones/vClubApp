{
  "environment": {
    "debug": {
      "console_command": "firebase emulators:start --project demo-vicinum-project",
      "firestore_emulator_host": "localhost:8080",
      "project_id": "demo-vicinum-project"
    },
    "production": {
      "firestore_emulator_host": null,
      "project_id": "vicinum-production-id"
    }
  },
  "schema": {

    "countries": {
      "primary_key": "country_iso3",
      "fields": {
        "country_iso2": { "type": "string", "required": true, "nullable": false },
        "country_iso3": { "type": "string", "required": true, "nullable": false },
        "country_name_local": { "type": "string", "required": true, "nullable": false },
        "country_name_en": { "type": "string", "required": true, "nullable": false },
        "country_name_es": { "type": "string", "required": false },
        "country_name_fr": { "type": "string", "required": false },
        "country_name_hi": { "type": "string", "required": false },
        "country_name_ar": { "type": "string", "required": false },
        "country_name_zn": { "type": "string", "required": false },
        "isCountryOnboarded": { "type": "boolean", "required": false, "default": false }
      }
    },
    "subdivisions": {
      "primary_key": "subdivision_code",
      "fields": {
        "subdivision_code": { "type": "string", "required": true, "nullable": false },
        "country_iso3": { "type": "string", "required": true , "nullable": false},
        "subdivision_name_local": { "type": "string", "required": true , "nullable": false},
        "subdivision_name_en": { "type": "string", "required": true , "nullable": false},
        "subdivision_name_es": { "type": "string", "required": false },
        "subdivision_name_fr": { "type": "string", "required": false },
        "subdivision_name_hi": { "type": "string", "required": false },
        "subdivision_name_ar": { "type": "string", "required": false },
        "subdivision_category": { "type": "string", "required": true },
        "isSubdivisionOnboarded": { "type": "boolean", "required": false, "default": false }
      }
    },
    "towns": {
      "primary_key": "town_unicode",
      "fields": {
        "town_unicode": { "type": "string", "required": true, "nullable": false },
        "subdivision_code": { "type": "string", "required": true, "nullable": false },
        "town_name_local": { "type": "string", "required": true, "nullable": false },
        "town_name_en": { "type": "string", "required": true, "nullable": false },
        "town_name_es": { "type": "string", "required": false },
        "town_name_fr": { "type": "string", "required": false },
        "town_name_hi": { "type": "string", "required": false },
        "town_name_ar": { "type": "string", "required": false },
        "town_name_zn": { "type": "string", "required": false },   
        "town_population": { "type": "int", "required": false, "default": 0 },
        "latitude": { "type": "double", "required": false },
        "longitude": { "type": "double", "required":false }
      }
    },
    "members": {
      "primary_key": "member_id",
      "fields": {
        "member_id": { "type": "string", "required": true, "mutable": false ,"nullable": false,"hint":"using Firebase SDK to ensure unique value"},
        "username": { "type": "string", "required": false, "mutable": true , "nullable": true,"mockup_value":"new_username","hint":"Username are decorators as benefits from Ambassadors up"},
        "email": { "type": "string", "required": true, "mutable": true,"nullable": false, "mockup_value":"new_email","hint":"through error and comeback to signup page if existing email match new" },
        "town_unicode": { "type": "string", "required": true, "nullable": false, "mockup_value":"US-CA-M0180", "hint":"Marina del Rey unicode set as mockup value" },           
        "member_status": { "type": "List", "required": true, "nullable": false, "default": "rookie", "options":"Rookie,Ambassador,Associated,Overdue,Banned"},
        "vcoin_balance": { "type": "double", "required": true,"mutable":true, "nullable": false,"default":0,"hint":"balance from subcollection ledger" },
        "reward_tree": {
          "type": "map",
          "required": true,
          "fields": {
            "recruiter_id": { "type": "string", "required": true, "nullable": false,"default": "admin_L1" },
            "coach_id": { "type": "string", "required": true, "nullable": false, "default": "admin_L1" },
            "mentor_id": { "type": "string", "required": true,"nullable": false, "default": "admin_L2" },
            "master_id": { "type": "string", "required": true, "nullable": false,"default": "admin_L3" }
          }
        },
        "member_profile": {
          "type": "map",
          "required": true,
          "fields": {
            "first_name": { "type": "string", "required": false },
            "last_name": { "type": "string", "required": false },
            "is_anonymous": { "type": "boolean", "required": true, "default": false },
            "language": { "type": "string", "required": true, "default": "en" }
          }
        }
      },
      "subcollections": {
          "bank_accounts": {
          "primary_key": "bank_id",
          "fields": {
            "owner_name": { "type": "string", "required": false },
            "bank_name": { "type": "string", "required": false },
            "bank_address":{"type": "string", "required": false},
            "bank_account_no": { "type": "string", "required": false, "default": "vCoin" },
            "bank_routing_no": { "type": "double", "required": false, "default": 1.0 },
            "currency": { "type": "string", "required": false },
            "type": { "type": "string", "required": false }
          }
        },

        "donations_given": {
          "primary_key": "donation_id",
          "fields": {
            "campaign_id": { "type": "string", "required": true, "nullable": false },
            "original_currency": { "type": "string", "required": true, "nullable": false, "default": "vCoin" },
            "fx_rate": { "type": "double", "required": true, "nullable": false, "default": 1.0 },
            "amount_vcoin": { "type": "double", "required": true , "nullable": false, "default":0.0 },
            "timestamp": { "type": "timestamp", "required": true, "nullable": false }
          }
        },
        "volunteering_hours": {
          "primary_key": "attendance_id",
          "fields": {
            "opportunity_id": { "type": "string", "required": true, "nullable": false },
            "opportunitty_title": { "type": "string", "required": true, "nullable": false , "default":"Opportunitties Require a descriptive title"},
            "opportunitty_description": { "type": "block", "required": false, "nullable": true, "hint":"Full or no description as the title can suffice" },
            "hours": { "type": "double", "required": false , "hint":"hours are nice to have but could be a permanent position"},
            "date": { "type": "timestamp", "required": false }
          }
        },
        "vcoin_ledger": {
          "primary_key": "entry_id",
          "fields": { 
            "amount": { "type": "double", "required": true,"mutable":false, "hint":"explicit amount required or through an error "},
            "source":{"type":"string","required": true,"mutable":false , "hint":" member_username from where this coming from " },
            "transaction_type": { "type": "List", "options":"credit,debit","required": true , "nullable":false, "mutable":false},
            "reference":{"type": "string", "required": false ,"mutable":false,"hint":"Custom field for member to understand this transaction"},
            "created_at": { "type": "timestamp", "required": true ,"mutable":false}
          }
        },
          "vcoin_exchange": {
          "primary_key": "exchange_id",
          "fields": {
            "amount": { "type": "double", "required": true,"mutable":false, "hint":"explicit amount required or through an error " },
            "fx_rate": { "type": "double", "required": true,"mutable":false , "default": 1.0 },
            "original_currency": { "type": "string", "required": true, "mutable":false , "default": "vCoin" },
            "source":{"type":"string","required": true,"mutable":false , "hint":" options are from vcoin wallet or any associated bank from member's profile " },
            "destination":{"type":"string","required": true,"mutable":false , "hint":" to own wallet or withdrawal to any associated bank from member's profile" },
            "destination_currency": { "type": "string", "required": true, "mutable":false ,"default": "vCoin" },
            "transaction_type": { "type": "List", "options":"credit,debit","required": true , "nullable":false,"mutable":false, "hint":"explicit type required or through an error "},
            "reference":{"type": "string", "required": false ,"mutable":false,"hint":"Custom field for member to understand this transaction"},
            "created_at": { "type": "timestamp", "required": true ,"mutable":false}
          }
        }
      }
    }
  }
}
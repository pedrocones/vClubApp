{
  "environment": {
    "debug": {
      "console command":"firebase emulators:start --project demo-vicinum-project",
      "firestore_emulator_host": "localhost:8080",
      "project_id": "demo-vicinum-project"
    },
    "production": {
      "firestore_emulator_host": null,
      "project_id": "vicinum-production-id"
    }
  },
  "schema": {
    "countries": {
      "primary_key": "country_iso3",
      "fields": {
        "country_iso2": { "required": true },
        "country_iso3": { "required": true },
        "country_name_local": { "required": true },
        "country_name_en": { "required": true },
        "country_name_es": { "required": false },
        "country_name_fr": { "required": false },
        "country_name_hi": { "required": false },
        "country_name_ar": { "required": false },
        "country_name_zn": { "required": false },
        "isCountryOnboarded": { "required": false }
      }
    },
    "subdivisions": {
      "primary_key": "subdivision_code",
      "fields": {
        "subdivision_code": { "required": true },
        "country_iso2": { "required": true },
        "country_iso3": { "required": true },
        "subdivision_name_local": { "required": true },
        "subdivision_name_en": { "required": true },
        "subdivision_name_es": { "required": false },
        "subdivision_name_fr": { "required": false },
        "subdivision_name_hi": { "required": false },
        "subdivision_name_ar": { "required": false },
        "subdivision_name_zn": { "required": false },
        "subdivision_category": { "required": true },
        "isSubdivisionOnboarded": { "required": false }
      }
    },
    "towns": {
      "primary_key": "town_unicode",
      "fields": {
        "town_code": { "required": true },
        "subdivision_code": { "required": true },
        "town_unicode": { "required": true },
        "town_name_local": { "required": true },
        "town_name_en": { "required": true },
        "town_name_es": { "required": false },
        "town_name_fr": { "required": false },
        "town_name_hi": { "required": true },
        "town_name_ar": { "required": false },
        "town_name_zn": { "required": false },
        "town_population": { "required": false },
        "town_last_census": { "required": false },
        "town_latitude": { "required": false },
        "town_longitude": { "required": false },
        "sustainable_living_index": { "required": false },
        "status_flag": { "required": false },
        "isFieldChange": { "required": false },
        "remarks": { "required": false }
      }
    }
  }
}